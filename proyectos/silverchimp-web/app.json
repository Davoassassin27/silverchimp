{
  "expo": {
    "name": "SilverChimp",
    "slug": "silverchimp-web",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "silverchimp",
    "userInterfaceStyle": "automatic",
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "SilverChimp",
      "shortName": "SilverChimp",
      "lang": "es",
      "scope": "./",
      "startUrl": "./",
      "display": "standalone",
      "backgroundColor": "#0B0F19",
      "themeColor": "#7A5AF8"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1F2937",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}